# Provider selection: "openai", "gemini", or "anthropic"
AI_PROVIDER=openai

# OpenAI — used by both Vercel AI SDK and LangChain
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4.1-nano

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY is used by Vercel AI SDK (@ai-sdk/google)
# GOOGLE_API_KEY is used by LangChain (@langchain/google-genai)
# Set both to the same value
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
